{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/api/cron/sync-all/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/daily-digest/route.ts": {
      "maxDuration": 300
    },
    "app/api/gmail/refresh-bodies/route.ts": {
      "maxDuration": 120
    },
    "app/api/topics/rematch/route.ts": {
      "maxDuration": 120
    },
    "app/api/voice/learn/route.ts": {
      "maxDuration": 120
    },
    "app/api/email/[id]/calendar/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-all",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/snooze-resurface",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/commitments",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/nudges",
      "schedule": "0 9,15 * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/checkin-emails",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/gmail-watch-refresh",
      "schedule": "0 4 * * *"
    }
  ]
}
