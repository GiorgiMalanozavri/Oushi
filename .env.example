# ====================================
# Required for production (Vercel)
# ====================================

# Supabase — get from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Google OAuth — get from Google Cloud Console → APIs & Services → Credentials
# In production, GOOGLE_REDIRECT_URI must be https://YOUR-DOMAIN/api/gmail/callback
# (no http, no localhost). Update it in Google Cloud Console authorized redirect URIs too.
GOOGLE_CLIENT_ID=346428756755-xxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx
GOOGLE_REDIRECT_URI=https://oushi.app/api/gmail/callback

# Anthropic — get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxx

# Cron secret — generate a fresh one for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used to authenticate Vercel Cron requests to /api/cron/* endpoints.
CRON_SECRET=replace-with-fresh-random-64-char-hex-string

# Public app URL — used in email links (e.g. digest "Open Oushi" button).
# Must be the actual production URL with no trailing slash.
NEXT_PUBLIC_APP_URL=https://oushi.app
